---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Get in Touch" description="Multiple ways to reach me. Email, phone, social media, or use the contact form.">
  <!-- Hero Section -->
  <section id="hero" class="relative pt-20 pb-12 lg:pt-32 lg:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent -z-10"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-foreground">
        Contact Us
      </h1>
      <p class="text-lg text-muted-foreground max-w-3xl mx-auto">
        Have a project in mind? Let's discuss how we can help bring your vision to life.
      </p>
    </div>
  </section>

  <!-- Contact Methods Grid -->
  <section id="contact-methods" class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
        <!-- Email -->
        <div class="bg-card rounded-xl border border-border p-8 text-center space-y-4 hover:shadow-lg transition-all duration-300">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground">Email</h3>
          <a href="mailto:khandanish0503@gmail.com" class="text-primary hover:text-primary/80 transition-colors">
            khandanish0503@gmail.com
          </a>
          <p class="text-sm text-muted-foreground">Response in 24 hours</p>
        </div>

        <!-- Phone -->
        <div class="bg-card rounded-xl border border-border p-8 text-center space-y-4 hover:shadow-lg transition-all duration-300">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground">Phone</h3>
          <a href="tel:+917978854373" class="text-primary hover:text-primary/80 transition-colors">
            +91 79788 54373
          </a>
          <p class="text-sm text-muted-foreground">Available Mon-Fri, 10 AM - 6 PM IST</p>
        </div>

        <!-- Support Email -->
        <div class="bg-card rounded-xl border border-border p-8 text-center space-y-4 hover:shadow-lg transition-all duration-300">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground">Support Email</h3>
          <a href="mailto:mdmarufalam315@gmail.com" class="text-primary hover:text-primary/80 transition-colors">
            mdmarufalam315@gmail.com
          </a>
          <p class="text-sm text-muted-foreground">Response in 24 hours</p>
        </div>

        <!-- Support Phone -->
        <div class="bg-card rounded-xl border border-border p-8 text-center space-y-4 hover:shadow-lg transition-all duration-300">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground">Support Line</h3>
          <a href="tel:+917258032880" class="text-primary hover:text-primary/80 transition-colors">
            +91 72580 32880
          </a>
          <p class="text-sm text-muted-foreground">Available Mon-Fri, 10 AM - 6 PM IST</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="max-w-4xl mx-auto">
        <div class="bg-gradient-to-br from-primary/5 to-transparent rounded-xl border border-border p-8 lg:p-12">
          <h2 class="text-3xl font-bold text-foreground mb-8">Send Me a Message</h2>

          <form data-form-id="7067b5c4-7c37-44d1-85fb-fd5b7b6222e3" class="space-y-6">
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
              <p class="text-sm text-blue-800">
                <span class="font-semibold">Pro Tip:</span> Fill out all fields to get a faster response and a more accurate quote for your project.
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="full_name" class="block text-sm font-semibold text-foreground mb-2">
                  Full Name <span class="text-primary">*</span>
                </label>
                <input
                  type="text"
                  id="full_name"
                  name="full_name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all duration-200"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email_address" class="block text-sm font-semibold text-foreground mb-2">
                  Email Address <span class="text-primary">*</span>
                </label>
                <input
                  type="email"
                  id="email_address"
                  name="email_address"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all duration-200"
                  placeholder="your@email.com"
                />
              </div>
            </div>

            <div>
              <label for="phone" class="block text-sm font-semibold text-foreground mb-2">
                Phone Number (Optional)
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-4 py-3 rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
                placeholder="+91 98765 43210"
              />
            </div>

            <div>
              <label for="project_type" class="block text-sm font-semibold text-foreground mb-2">
                Project Type <span class="text-primary">*</span>
              </label>
              <select
                id="project_type"
                name="project_type"
                required
                class="w-full px-4 py-3 rounded-lg border border-border bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
              >
                <option value="">Select a project type</option>
                <option value="Web Design">Web Design</option>
                <option value="UI/UX Design">UI/UX Design</option>
                <option value="Branding">Branding</option>
                <option value="Digital Marketing">Digital Marketing</option>
                <option value="Consultation">Consultation</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div>
              <label for="budget_range" class="block text-sm font-semibold text-foreground mb-2">
                Budget Range (₹)
              </label>
              <select
                id="budget_range"
                name="budget_range"
                class="w-full px-4 py-3 rounded-lg border border-border bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
              >
                <option value="">Select a budget range</option>
                <option value="Under ₹15,000">Under ₹15,000</option>
                <option value="₹15,000 - ₹40,000">₹15,000 - ₹40,000</option>
                <option value="₹40,000 - ₹75,000">₹40,000 - ₹75,000</option>
                <option value="₹75,000+">₹75,000+</option>
              </select>
            </div>

            <div>
              <label for="project_details" class="block text-sm font-semibold text-foreground mb-2">
                Project Details <span class="text-primary">*</span>
              </label>
              <textarea
                id="project_details"
                name="project_details"
                required
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
                placeholder="Tell me about your project, goals, and timeline..."
              ></textarea>
            </div>

            <div class="pt-4">
              <button
                type="submit"
                class="w-full px-8 py-4 bg-primary text-primary-foreground font-semibold rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0"
              >
                Send Message & Get Free Consultation
              </button>
              <p class="text-center text-xs text-muted-foreground mt-4">
                ✓ No spam • ✓ Fast response • ✓ Free initial consultation
              </p>
            </div>
          </form>

          <div id="b12-form-done-7067b5c4-7c37-44d1-85fb-fd5b7b6222e3" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800">
            <p class="font-semibold">Thank you for your message!</p>
            <p class="text-sm">I'll get back to you as soon as possible.</p>
          </div>

          <div id="b12-form-error-7067b5c4-7c37-44d1-85fb-fd5b7b6222e3" class="hidden mt-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800">
            <p class="font-semibold">Oops! Something went wrong.</p>
            <p class="text-sm">Please try again or contact me directly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Office Hours Section -->
  <section id="office-hours" class="py-16 lg:py-24 bg-card">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-6">
          <h2 class="text-2xl font-bold text-foreground">Office Hours</h2>
          <div class="space-y-4">
            <div class="flex justify-between items-center py-3 border-b border-border">
              <span class="text-foreground font-semibold">Monday - Friday</span>
              <span class="text-muted-foreground">10 AM - 6 PM IST</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-border">
              <span class="text-foreground font-semibold">Saturday</span>
              <span class="text-muted-foreground">10 AM - 2 PM IST</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-border">
              <span class="text-foreground font-semibold">Sunday</span>
              <span class="text-muted-foreground">Closed</span>
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <h2 class="text-2xl font-bold text-foreground">Response Times</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <span class="text-primary font-bold">1</span>
              </div>
              <div>
                <h3 class="font-semibold text-foreground">Quick Questions</h3>
                <p class="text-sm text-muted-foreground">Response within 4 hours</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <span class="text-primary font-bold">2</span>
              </div>
              <div>
                <h3 class="font-semibold text-foreground">Project Inquiries</h3>
                <p class="text-sm text-muted-foreground">Response within 24 hours</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <span class="text-primary font-bold">3</span>
              </div>
              <div>
                <h3 class="font-semibold text-foreground">Proposals</h3>
                <p class="text-sm text-muted-foreground">Within 2-3 business days</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
