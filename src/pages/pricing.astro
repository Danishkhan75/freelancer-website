---
import Layout from '../layouts/Layout.astro';
import PricingCards from '../components/PricingCards';

const pricingPlans = [
  {
    name: 'Starter',
    description: 'Perfect for small projects and startups',
    price: '₹15,000',
    priceOriginal: '$180',
    duration: 'one-time',
    amount: 15000,
    packageType: 'starter' as const,
    features: [
      'Single service (4-6 weeks)',
      'Up to 3 revision rounds',
      'Email support',
      'Project consultation',
      'Basic design deliverables',
    ],
    cta: 'Get Started',
    highlight: false,
  },
  {
    name: 'Professional',
    description: 'Ideal for growing businesses',
    price: '₹40,000',
    priceOriginal: '$480',
    duration: 'one-time',
    amount: 40000,
    packageType: 'professional' as const,
    features: [
      'Multiple services package',
      'Up to 5 revision rounds',
      'Priority email & chat support',
      'Strategy consultation',
      'Advanced design deliverables',
      'Unlimited meetings',
      'Brand guidelines document',
    ],
    cta: 'Most Popular',
    highlight: true,
  },
  {
    name: 'Enterprise',
    description: 'Complete solution for established brands',
    price: '₹75,000+',
    priceOriginal: '$900+',
    duration: 'custom',
    amount: 75000,
    packageType: 'enterprise' as const,
    features: [
      'Full-service package',
      'Unlimited revisions',
      '24/7 priority support',
      'Dedicated project manager',
      'Premium design system',
      'Weekly strategy calls',
      'Complete brand identity',
      'Post-launch optimization',
      'Long-term partnership',
    ],
    cta: 'Contact for Quote',
    highlight: false,
  },
];

const serviceAddOns = [
  { name: 'Additional Revision Round', price: '₹3,000', description: 'Extra revision beyond included rounds' },
  { name: 'Rush Service (3 days)', price: '₹5,000', description: 'Expedited delivery' },
  { name: 'Content Writing', price: '₹150/100 words', description: 'Professional copywriting' },
  { name: 'SEO Optimization', price: '₹8,000', description: 'Search engine optimization' },
  { name: 'Social Media Design', price: '₹5,000', description: 'Graphics for social platforms' },
  { name: 'Maintenance Package (Monthly)', price: '₹10,000', description: 'Ongoing updates & support' },
];
---

<Layout title="Pricing - Freelancer Services" description="Transparent pricing for professional freelance services in Indian Rupees (INR).">
  <!-- Hero Section -->
  <section id="hero" class="relative pt-20 pb-12 lg:pt-32 lg:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent -z-10"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-foreground">
        Pricing
      </h1>
      <p class="text-lg text-muted-foreground max-w-3xl mx-auto">
        Transparent pricing in Indian Rupees (₹). Choose the perfect plan for your project needs.
      </p>
    </div>
  </section>

  <!-- Pricing Plans -->
  <section id="pricing-plans" class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-muted-foreground text-lg mb-2">
          All prices in Indian Rupees (₹) | Equivalent USD shown for reference
        </p>
      </div>

      <PricingCards client:load plans={pricingPlans} />
    </div>
  </section>

  <!-- Add-on Services -->
  <section id="add-ons" class="py-16 lg:py-24 bg-card">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Service Add-ons</h2>
        <p class="text-lg text-muted-foreground">
          Enhance your package with additional services
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceAddOns.map((addon) => (
          <div class="bg-background rounded-lg border border-border p-6 space-y-3">
            <h3 class="text-lg font-semibold text-foreground">{addon.name}</h3>
            <p class="text-muted-foreground text-sm">{addon.description}</p>
            <div class="pt-4 border-t border-border">
              <div class="text-2xl font-bold text-primary">{addon.price}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Frequently Asked Questions</h2>
      </div>

      <div class="space-y-6">
        <details class="group bg-card rounded-lg border border-border p-6 cursor-pointer">
          <summary class="flex items-center justify-between font-semibold text-foreground">
            <span>Do you offer custom pricing?</span>
            <svg class="w-5 h-5 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </summary>
          <p class="text-muted-foreground mt-4">
            Yes! Complex projects often require custom quotes. Contact me to discuss your specific needs and I'll provide a tailored proposal.
          </p>
        </details>

        <details class="group bg-card rounded-lg border border-border p-6 cursor-pointer">
          <summary class="flex items-center justify-between font-semibold text-foreground">
            <span>Are payment plans available?</span>
            <svg class="w-5 h-5 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </summary>
          <p class="text-muted-foreground mt-4">
            Yes! For projects over ₹50,000, I offer flexible payment plans - 50% upfront and 50% upon completion.
          </p>
        </details>

        <details class="group bg-card rounded-lg border border-border p-6 cursor-pointer">
          <summary class="flex items-center justify-between font-semibold text-foreground">
            <span>Do you provide monthly maintenance?</span>
            <svg class="w-5 h-5 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </summary>
          <p class="text-muted-foreground mt-4">
            Absolutely! Monthly maintenance packages start at ₹10,000 and include regular updates, security checks, and performance optimization.
          </p>
        </details>

        <details class="group bg-card rounded-lg border border-border p-6 cursor-pointer">
          <summary class="flex items-center justify-between font-semibold text-foreground">
            <span>What's the delivery timeline?</span>
            <svg class="w-5 h-5 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </summary>
          <p class="text-muted-foreground mt-4">
            Standard delivery is 4-6 weeks. Rush services available for ₹5,000 additional charge (3-day delivery).
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section id="cta" class="py-16 lg:py-24 bg-gradient-to-r from-primary/10 to-primary/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Ready to get started?</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Contact me today to discuss your project and find the perfect solution for your needs.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/index#contact" class="inline-flex items-center justify-center px-8 py-4 bg-primary text-primary-foreground font-semibold rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all duration-300 hover:-translate-y-0.5">
          Get a Free Consultation
        </a>
        <a href="/blog" class="inline-flex items-center justify-center px-8 py-4 border-2 border-primary text-primary font-semibold rounded-lg hover:bg-primary/5 transition-all duration-300">
          Learn More on Blog
        </a>
      </div>
    </div>
  </section>

  <style>
    details summary::-webkit-details-marker {
      display: none;
    }
  </style>
</Layout>
