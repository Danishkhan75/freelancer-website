---
import Layout from '../layouts/Layout.astro'
import ForgotPasswordForm from '../components/auth/ForgotPasswordForm'
---

<Layout title="Reset Password - Freelancer Platform">
  <main class="min-h-screen bg-gradient-to-b from-slate-50 to-slate-100 py-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-md">
      <div class="bg-white rounded-lg shadow-md p-8">
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Reset Password</h1>
        <p class="text-slate-600 mb-8">Enter your email to receive a password reset link</p>

        <ForgotPasswordForm client:load />

        <p class="text-center text-slate-600 text-sm mt-6">
          Remember your password?
          <a href="/login" class="text-primary hover:underline font-semibold">Sign in here</a>
        </p>
      </div>
    </div>
  </main>
</Layout>

<style>
  @import "../styles/global.css";
</style>
