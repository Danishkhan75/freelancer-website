---
import Layout from '../../layouts/Layout.astro'
import ResetPasswordForm from '../../components/auth/ResetPasswordForm'
---

<Layout title="Set New Password">
  <main class="min-h-screen bg-gradient-to-b from-slate-50 to-slate-100 py-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-md">
      <div class="bg-white rounded-lg shadow-md p-8">
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Set New Password</h1>
        <p class="text-slate-600 mb-8">Create a strong password for your account</p>

        <ResetPasswordForm client:load />
      </div>
    </div>
  </main>
</Layout>

<style>
  @import "../../styles/global.css";
</style>
