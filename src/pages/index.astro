      'Campaign management',
      'Growth strategy',
    ],
    price: '₹10,000 - ₹60,000/month',
    deliveryTime: 'Ongoing',
  },
  {
    title: 'Consultation & Strategy',
    description: 'Get expert guidance on digital strategy and business transformation.',
    benefits: [
      'Business analysis and planning',
      'Technology recommendations',
      'Process optimization',
      'Ongoing strategic support',
      'Market research',
      'Competitive analysis',
    ],
    price: '₹5,000 - ₹15,000/hour',
    deliveryTime: 'Flexible',
  },
  {
    title: 'Copywriting & Content',
    description: 'Craft compelling copy that communicates your value proposition.',
    benefits: [
      'Website copy and messaging',
