---

<Layout title="Freelancer - Professional Services" description="Professional freelance services for your business needs.">
  <!-- Hero Section -->
  <section id="hero" class="relative pt-20 pb-12 lg:pt-32 lg:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent -z-10"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6 animate-fade-up">
          <div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-foreground mb-4">
              Elevate Your Brand with Professional Freelance Services
            </h1>
            <p class="text-lg text-muted-foreground leading-relaxed">
              Trusted by companies worldwide. We bring expertise, creativity, and precision to every project.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-primary text-primary-foreground font-semibold rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all duration-300 hover:-translate-y-0.5">
              Request a Consultation
            </a>
            <a href="/gallery" class="inline-flex items-center justify-center px-8 py-4 border-2 border-primary text-primary font-semibold rounded-lg hover:bg-primary/5 transition-all duration-300">
              View Gallery
            </a>
          </div>
        </div>

        <div class="relative h-96 lg:h-full min-h-96 rounded-2xl overflow-hidden shadow-2xl animate-fade-up" style="animation-delay: 0.1s">
          <img
            src={heroImage}
            alt="Freelance work illustration"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-16 lg:py-24 bg-card">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">About Our Team</h2>
            <p class="text-muted-foreground leading-relaxed mb-4">
              We are Danish Khan, Md Maruf Alam, and Jaya Singh - three passionate freelancers pursuing B.Tech from Lovely Professional University, currently in our 2nd year.
            </p>
            <p class="text-muted-foreground leading-relaxed mb-4">
              With 2+ years of combined experience in digital design and development, we've successfully completed 30+ projects with 100% client satisfaction. We're committed to delivering beautiful, functional solutions that exceed expectations.
            </p>
            <p class="text-muted-foreground leading-relaxed">
              Our philosophy focuses on collaboration, clarity, and quality. We believe the best work happens when clients and designers work as true partners to transform visions into reality.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4 pt-4">
            <div class="bg-primary/10 rounded-lg p-6 border border-primary/20">
              <div class="text-3xl font-bold text-primary mb-2">2+</div>
              <p class="text-sm text-muted-foreground">Years Experience</p>
            </div>
            <div class="bg-primary/10 rounded-lg p-6 border border-primary/20">
              <div class="text-3xl font-bold text-primary mb-2">30+</div>
              <p class="text-sm text-muted-foreground">Projects Completed</p>
            </div>
            <div class="bg-primary/10 rounded-lg p-6 border border-primary/20">
              <div class="text-3xl font-bold text-primary mb-2">100%</div>
              <p class="text-sm text-muted-foreground">Client Satisfaction</p>
            </div>
            <div class="bg-primary/10 rounded-lg p-6 border border-primary/20">
              <div class="text-3xl font-bold text-primary mb-2">LPU</div>
              <p class="text-sm text-muted-foreground">2nd Year B.Tech</p>
            </div>
          </div>
        </div>

        <div class="relative h-96 rounded-2xl overflow-hidden shadow-xl">
          <img
            src={profileImage}
            alt="Professional profile"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Services & Solutions</h2>
        <p class="text-lg text-muted-foreground max-w-3xl mx-auto">
          Comprehensive services tailored to your business needs. Click on any service to explore detailed information, pricing, and what's included.
        </p>
      </div>

      <ServiceSelector client:visible services={services} />
    </div>
  </section>

  <!-- Portfolio Section -->
  <section id="portfolio" class="py-16 lg:py-24 bg-card">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Portfolio</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          A showcase of past work, demonstrating skills and the quality of services provided through visuals and descriptions of completed projects.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {portfolioProjects.map((project) => (
          <PortfolioCard
            title={project.title}
            description={project.description}
            image={project.image}
            tags={project.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section with Carousel -->
  <section id="testimonials" class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Testimonials</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Positive feedback and success stories from previous clients establishing social proof.
        </p>
      </div>

      <TestimonialCarousel client:visible testimonials={testimonials} />
    </div>
  </section>

  <!-- Trust & Credentials Section -->
  <section id="trust" class="py-16 lg:py-24 bg-card">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Why Clients Trust Me</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Proven track record with measurable results and industry recognition.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Trust Item 1 -->
        <div class="bg-background rounded-lg border border-border p-6 text-center space-y-3 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">Quality Assured</h3>
          <p class="text-sm text-muted-foreground">100% satisfaction guarantee with rigorous quality checks</p>
        </div>

        <!-- Trust Item 2 -->
        <div class="bg-background rounded-lg border border-border p-6 text-center space-y-3 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">On-Time Delivery</h3>
          <p class="text-sm text-muted-foreground">Consistent track record of meeting deadlines</p>
        </div>

        <!-- Trust Item 3 -->
        <div class="bg-background rounded-lg border border-border p-6 text-center space-y-3 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">Secure & Confidential</h3>
          <p class="text-sm text-muted-foreground">Your data and projects are always protected</p>
        </div>

        <!-- Trust Item 4 -->
        <div class="bg-background rounded-lg border border-border p-6 text-center space-y-3 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">Expert Support</h3>
          <p class="text-sm text-muted-foreground">24/7 responsive support throughout projects</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section id="newsletter" class="py-16 lg:py-24 bg-gradient-to-r from-primary/10 via-primary/5 to-primary/10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center space-y-8">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Stay Updated</h2>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
            Subscribe to our newsletter for latest insights on freelancing, design trends, and industry tips.
          </p>
        </div>

        <form class="flex flex-col sm:flex-row gap-4 max-w-2xl mx-auto w-full">
          <input
            type="email"
            placeholder="your@email.com"
            required
            class="flex-1 px-6 py-4 rounded-lg border border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50"
          />
          <button
            type="submit"
            class="px-8 py-4 bg-primary text-primary-foreground font-semibold rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all duration-300 hover:-translate-y-0.5 whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>

        <p class="text-sm text-muted-foreground">
          No spam, unsubscribe anytime. I respect your privacy.
        </p>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="process" class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Our Process</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          How we bring your vision to life through a strategic and collaborative approach.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="relative">
          <div class="bg-primary/10 border-2 border-primary rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-primary">1</span>
          </div>
          <h3 class="text-lg font-semibold text-foreground text-center mb-3">Discovery</h3>
          <p class="text-sm text-muted-foreground text-center">
            Understanding your goals, target audience, and project requirements through in-depth consultation.
          </p>
          <div class="hidden md:block absolute top-24 right-0 w-1/2 h-1 bg-gradient-to-r from-primary to-transparent"></div>
        </div>

        <div class="relative">
          <div class="bg-primary/10 border-2 border-primary rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-primary">2</span>
          </div>
          <h3 class="text-lg font-semibold text-foreground text-center mb-3">Strategy</h3>
          <p class="text-sm text-muted-foreground text-center">
            Developing a comprehensive strategy and creating wireframes, mockups, and technical specifications.
          </p>
          <div class="hidden md:block absolute top-24 right-0 w-1/2 h-1 bg-gradient-to-r from-primary to-transparent"></div>
        </div>

        <div class="relative">
          <div class="bg-primary/10 border-2 border-primary rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-primary">3</span>
          </div>
          <h3 class="text-lg font-semibold text-foreground text-center mb-3">Design & Build</h3>
          <p class="text-sm text-muted-foreground text-center">
            Creating beautiful, functional designs and building solutions that exceed expectations.
          </p>
          <div class="hidden md:block absolute top-24 right-0 w-1/2 h-1 bg-gradient-to-r from-primary to-transparent"></div>
        </div>

        <div class="relative">
          <div class="bg-primary/10 border-2 border-primary rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-primary">4</span>
          </div>
          <h3 class="text-lg font-semibold text-foreground text-center mb-3">Launch & Support</h3>
          <p class="text-sm text-muted-foreground text-center">
            Launching your project and providing ongoing support to ensure continued success.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Matrix Section -->
  <section id="skills" class="py-16 lg:py-24 bg-card">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Our Skills & Expertise</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          A comprehensive overview of our technical skills and proficiency levels across multiple disciplines.
        </p>
      </div>
      <SkillsMatrix client:visible />
    </div>
  </section>

  <!-- Client Results Section -->
  <section id="results" class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Client Success Stories</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Real results from real clients. See how I've helped businesses succeed.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Result 1 -->
        <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl border border-primary/20 p-8 space-y-4">
          <div class="flex items-baseline gap-2">
            <span class="text-4xl font-bold text-primary">45%</span>
            <span class="text-muted-foreground">Increase</span>
          </div>
          <h3 class="font-semibold text-foreground text-lg">Website Traffic</h3>
          <p class="text-sm text-muted-foreground">
            Optimized digital presence led to 45% surge in organic traffic within 3 months.
          </p>
        </div>

        <!-- Result 2 -->
        <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl border border-primary/20 p-8 space-y-4">
          <div class="flex items-baseline gap-2">
            <span class="text-4xl font-bold text-primary">3x</span>
            <span class="text-muted-foreground">More</span>
          </div>
          <h3 class="font-semibold text-foreground text-lg">Lead Generation</h3>
          <p class="text-sm text-muted-foreground">
            Strategic redesign tripled qualified leads and improved conversion rates.
          </p>
        </div>

        <!-- Result 3 -->
        <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-xl border border-primary/20 p-8 space-y-4">
          <div class="flex items-baseline gap-2">
            <span class="text-4xl font-bold text-primary">₹50L+</span>
            <span class="text-muted-foreground">Revenue</span>
          </div>
          <h3 class="font-semibold text-foreground text-lg">Client Growth</h3>
          <p class="text-sm text-muted-foreground">
            Helped clients generate over 50 lakhs in additional revenue through design.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Advanced Features Section -->
  <section id="features" class="py-16 lg:py-24 bg-card">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
