---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  author?: string;
  pubDate?: Date;
  image?: string;
  tags?: string[];
}

const { title, description, author = 'Professional Freelancer', pubDate, image, tags = [] } = Astro.props;

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
};
---

<Layout title={title} description={description}>
  <!-- Blog Post Header -->
  <section class="relative py-12 lg:py-20 bg-gradient-to-b from-primary/10 to-transparent">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      <a href="/blog" class="inline-flex items-center text-primary hover:text-primary/80 transition-colors mb-4">
        ← Back to Blog
      </a>

      <div class="space-y-4">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="inline-block px-3 py-1 bg-primary/20 text-primary text-sm font-semibold rounded-full">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-5xl font-bold text-foreground leading-tight">
          {title}
        </h1>

        <div class="flex flex-wrap items-center gap-6 text-muted-foreground">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"></path>
            </svg>
            <span>{author}</span>
          </div>
          {pubDate && (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v2h16V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
              </svg>
              <time>{formatDate(pubDate)}</time>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {image && (
    <section class="py-8 lg:py-12">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative h-96 lg:h-96 rounded-xl overflow-hidden shadow-xl">
          <img
            src={image}
            alt={title}
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </section>
  )}

  <!-- Blog Content -->
  <section class="py-12 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none text-foreground">
        <slot />
      </article>
    </div>
  </section>

  <!-- Back to Blog Link -->
  <section class="py-12 lg:py-16 bg-card">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-6">
      <h2 class="text-2xl font-bold text-foreground">Ready to work together?</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto">
        Get in touch to discuss your project and how I can help bring your vision to life.
      </p>
      <a href="/index#contact" class="inline-flex items-center justify-center px-8 py-4 bg-primary text-primary-foreground font-semibold rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all duration-300 hover:-translate-y-0.5">
        Get Started Today
      </a>
    </div>
  </section>

  <style is:global>
    article.prose {
      line-height: 1.8;
    }

    article.prose h2 {
      font-size: 1.5rem;
      line-height: 2rem;
      font-weight: 700;
      margin-top: 2rem;
      margin-bottom: 1rem;
      color: var(--color-foreground);
    }

    article.prose h3 {
      font-size: 1.25rem;
      line-height: 1.75rem;
      font-weight: 700;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      color: var(--color-foreground);
    }

    article.prose p {
      margin-bottom: 1rem;
      color: var(--color-muted-foreground);
    }

    article.prose ul,
    article.prose ol {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
      color: var(--color-muted-foreground);
    }

    article.prose li {
      margin-bottom: 0.5rem;
    }

    article.prose strong {
      font-weight: 600;
      color: var(--color-foreground);
    }

    article.prose code {
      background-color: var(--color-muted);
      padding-left: 0.5rem;
      padding-right: 0.5rem;
      padding-top: 0.25rem;
      padding-bottom: 0.25rem;
      border-radius: 0.375rem;
      font-size: 0.875rem;
      font-family: monospace;
    }

    article.prose blockquote {
      border-left: 4px solid var(--color-primary);
      padding-left: 1rem;
      font-style: italic;
      color: var(--color-muted-foreground);
      margin-top: 1.5rem;
      margin-bottom: 1.5rem;
    }
  </style>
</Layout>
