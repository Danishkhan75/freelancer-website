---
interface Props {
  title: string;
  description: string;
  benefits: string[];
  icon?: string;
}

const { title, description, benefits, icon } = Astro.props;
---

<div class="bg-card rounded-xl p-8 border border-border hover:shadow-lg hover:border-primary/30 transition-all duration-300">
  {icon && (
    <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
      <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox={icon}>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
      </svg>
    </div>
  )}
  <h3 class="text-xl font-semibold mb-3 text-foreground">{title}</h3>
  <p class="text-muted-foreground mb-4">{description}</p>
  <ul class="space-y-2">
    {benefits.map((benefit) => (
      <li class="flex items-start">
        <span class="text-primary mr-3 mt-1">✓</span>
        <span class="text-sm text-foreground">{benefit}</span>
      </li>
    ))}
  </ul>
</div>
