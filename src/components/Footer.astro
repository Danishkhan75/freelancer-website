---
import B12Link from './B12Link.astro';
---

<footer class="bg-background border-t border-border mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 mb-8">
      <div>
        <div class="flex items-center space-x-2 mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <span class="text-lg font-bold">Freelancer</span>
        </div>
        <p class="text-sm text-muted-foreground">Professional freelance services for your business needs.</p>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Explore</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="text-muted-foreground hover:text-primary transition-colors">About Me</a></li>
          <li><a href="/gallery" class="text-muted-foreground hover:text-primary transition-colors">Gallery</a></li>
          <li><a href="/blog" class="text-muted-foreground hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/case-studies" class="text-muted-foreground hover:text-primary transition-colors">Case Studies</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Services</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/#services" class="text-muted-foreground hover:text-primary transition-colors">All Services</a></li>
          <li><a href="/services-comparison" class="text-muted-foreground hover:text-primary transition-colors">Comparison</a></li>
          <li><a href="/pricing" class="text-muted-foreground hover:text-primary transition-colors">Pricing (₹)</a></li>
          <li><a href="/certifications" class="text-muted-foreground hover:text-primary transition-colors">Certifications</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Get Started</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/contact" class="text-muted-foreground hover:text-primary transition-colors">Contact Me</a></li>
          <li><a href="/book-consultation" class="text-muted-foreground hover:text-primary transition-colors">Book Consultation</a></li>
          <li><a href="/faq" class="text-muted-foreground hover:text-primary transition-colors">FAQ</a></li>
          <li><a href="/roadmap" class="text-muted-foreground hover:text-primary transition-colors">Roadmap</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold mb-4">Connect</h3>
        <div class="flex space-x-3 mb-4">
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
            </svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7s2.75 9.08 9 9.91z"></path>
            </svg>
          </a>
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
          </a>
        </div>
        <p class="text-xs text-muted-foreground">Email: <a href="mailto:khandanish0503@gmail.com" class="hover:text-primary transition-colors">khandanish0503@gmail.com</a></p>
      </div>
    </div>

    <div class="border-t border-border pt-8 flex flex-col md:flex-row items-center justify-between">
      <p class="text-sm text-muted-foreground">© 2026 Freelancer. All rights reserved.</p>
      <B12Link />
    </div>
  </div>
</footer>
